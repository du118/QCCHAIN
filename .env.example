# 环境变量配置（复制此文件为 .env 并填入真实值）

# 部署者私钥（不要泄露！）
PRIVATE_KEY=your_private_key_here

# RPC 节点 URL
SEPOLIA_RPC_URL=https://rpc.sepolia.org
ETH_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com

# 区块浏览器 API Key
ETHERSCAN_API_KEY=your_etherscan_api_key
BSCSCAN_API_KEY=your_bscscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# CoinMarketCap API Key（用于 Gas 报告）
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key

# 代币分配地址（部署时替换为真实地址）
FOUNDER_ADDRESS=0x...
TEAM_ADDRESS=0x...
MINING_ADDRESS=0x...
ECOSYSTEM_ADDRESS=0x...
MARKETING_ADDRESS=0x...
COMMUNITY_ADDRESS=0x...
MAINTENANCE_ADDRESS=0x...

# Gas 报告
REPORT_GAS=false
